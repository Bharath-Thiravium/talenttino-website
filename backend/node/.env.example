PORT=5010
HOST=127.0.0.1
FRONTEND_URL=http://127.0.0.1:8080
FRONTEND_ORIGIN=http://127.0.0.1:8080,http://localhost:8080
TRUST_PROXY=1
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=talentteno_db
DB_USER=root
DB_PASSWORD=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-character-google-app-password
SMTP_FROM_NAME=Talentteno Institute
SMTP_FROM_EMAIL=your-gmail-address@gmail.com

OTP_MOBILE_LIMIT_PER_HOUR=5
OTP_IP_LIMIT_PER_HOUR=15
OTP_RESEND_SECONDS=60
OTP_EXPIRY_MINUTES=10

# SMS OTP delivery. Pick one provider and fill its credentials.
# SMS_PROVIDER=fast2sms
# FAST2SMS_API_KEY=your_fast2sms_api_key

# SMS_PROVIDER=msg91
# MSG91_AUTH_KEY=your_msg91_auth_key

# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_NUMBER=your_twilio_sms_number

# WhatsApp OTP delivery using Twilio WhatsApp.
# SMS_PROVIDER=twilio_whatsapp
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp OTP delivery using Meta WhatsApp Cloud API.
# SMS_PROVIDER=whatsapp
# WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token
# WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
# WHATSAPP_TEMPLATE_NAME=your_approved_otp_template_name
# WHATSAPP_TEMPLATE_LANGUAGE=en_US
# WHATSAPP_TEMPLATE_BUTTON_INDEX=0
